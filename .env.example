# ===== LLM API 密钥 (配置任一个即可启用 AI 专家分析) =====

# DeepSeek (推荐·国产·性价比高)
# 注册获取: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxx

# ZhipuAI 智谱 GLM (国产·多模型)
# 注册获取: https://open.bigmodel.cn
ZHIPU_API_KEY=xxxxx.xxxxxxxxxxxxxx

# Anthropic Claude
# 注册获取: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI / 兼容接口
# 注册获取: https://platform.openai.com
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
# 注册获取: https://aistudio.google.com
GEMINI_API_KEY=AIza...

# Ollama 本地大模型 (无需 API Key)
# 安装: https://ollama.com
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ===== Agent 设置 =====
ANAEROBIC_AGENT_LLM_PROVIDER=
ANAEROBIC_AGENT_LLM_MODEL=deepseek-chat
ANAEROBIC_AGENT_LLM_TIMEOUT=60
ANAEROBIC_AGENT_LOG=anaerobic_agent.log
ANAEROBIC_AGENT_LOG_LEVEL=INFO
